<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#fb7a8e">

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Categories"
        android:textColor="#000000"
        android:textSize="36sp"
        android:textStyle="bold"
        android:fontFamily="@font/poppins_bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="5dp"/>

    <!-- Row 1: Option 1 & Option 2 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/option1"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Science"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/science"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/option2"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/option2"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Math"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/math"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/titleText"
        app:layout_constraintStart_toEndOf="@id/option1"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="2dp"/>

    <!-- Row 2: Option 3 & Option 4 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/option3"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="History"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/his"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/option4"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="25dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/option4"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Art"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/art"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option2"
        app:layout_constraintStart_toEndOf="@id/option3"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="25dp"/>

    <!-- Row 3: Option 5 & Option 6 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/option5"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Geography"
        android:textSize="11sp"
        android:singleLine="false"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:gravity="center"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/geo"
        app:iconSize="74dp"
        app:iconPadding="4dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/option6"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="25dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/option6"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Sport"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/sport"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option4"
        app:layout_constraintStart_toEndOf="@id/option5"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="25dp"/>

    <!-- Row 4: Option 7 & Option 8 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/option7"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Food & Drinks"
        android:textSize="10sp"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/food"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/option8"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="25dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/option8"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Computer Science"
        android:textSize="10sp"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/computer"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option6"
        app:layout_constraintStart_toEndOf="@id/option7"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="25dp"/>

    <!-- Row 5: Option 9 & Option 10 -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/option9"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Movies & TvShows"
        android:textSize="10sp"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/movies"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option7"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/option8"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="25dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/option10"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:text="Flags"
        android:textSize="10sp"
        android:textColor="@android:color/black"
        android:fontFamily="@font/poppins_bold"
        android:background="@drawable/ctg"
        app:backgroundTint="@null"
        app:icon="@drawable/flag"
        app:iconSize="74dp"
        app:iconGravity="top"
        app:iconTint="@null"
        app:layout_constraintTop_toBottomOf="@id/option8"
        app:layout_constraintStart_toEndOf="@id/option9"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="25dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>