<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bgbg"
    android:orientation="vertical"
    android:gravity="top"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="40dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/home"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text=""
            android:background="@drawable/ctg"
            app:backgroundTint="@null"
            app:icon="@drawable/home"
            app:iconSize="30dp"
            app:iconTint="@android:color/black"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:padding="100dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Go to home"/>

        <TextView
            android:id="@+id/summaryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Summary"
            android:textColor="#000000"
            android:textSize="40sp"
            android:fontFamily="@font/poppins_bold"
            android:layout_marginStart="20dp"
            android:gravity="center"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/home"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:text=""
            android:background="@drawable/ctg"
            app:backgroundTint="@null"
            app:icon="@drawable/ic_menu"
            app:iconSize="30dp"
            app:iconTint="@android:color/black"
            app:iconPadding="0dp"
            app:iconGravity="textStart"
            android:padding="100dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="16dp"
            android:contentDescription="Go to menu"/>

    </LinearLayout>

    <ImageView
        android:id="@+id/trophy"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_marginTop="0dp"
        android:src="@drawable/trophy"
        android:layout_gravity="center_horizontal"
        app:layout_constraintEnd_toEndOf="@id/nameInput"
        app:layout_constraintStart_toStartOf="@id/nameInput"
        app:layout_constraintTop_toTopOf="@id/nameInput" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/labelCard"
        android:layout_width="360dp"
        android:layout_height="300dp"
        android:gravity="center_vertical"
        app:strokeWidth="0dp"
        app:cardElevation="0dp"
        android:clickable="true"
        android:focusable="true"
        app:cardCornerRadius="10dp"
        app:cardBackgroundColor="#80aab6fb"
        android:layout_gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="249dp"
            android:gravity="top"
            android:orientation="vertical"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <TextView
                android:id="@+id/labelText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="15dp"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center_vertical"
                android:text="Congratulations !"
                android:textColor="@android:color/black"
                android:textSize="25sp" />


            <TextView
                android:id="@+id/ScoreMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center_vertical"
                android:hint="You've scored points!"
                android:textColor="@android:color/black"
                android:textSize="14sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="16dp">

                <!-- Yes button -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/yes"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/yes" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="35"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"
                        android:gravity="center"/>
                </LinearLayout>

                <!-- Spacer between the two -->
                <Space
                    android:layout_width="50dp"
                    android:layout_height="wrap_content" />

                <!-- No button -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/np"
                        android:layout_width="100dp"
                        android:layout_height="100dp"
                        android:src="@drawable/no" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="#000000"
                        android:textSize="16sp"
                        android:layout_marginTop="8dp"
                        android:gravity="center"/>
                </LinearLayout>

            </LinearLayout>


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>




</LinearLayout>